{"id":15,"name":"最終考驗跳轉","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":13,"switch1Valid":true,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"tileId":0,"characterName":"People4","direction":2,"pattern":0,"characterIndex":1},"list":[{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["冒險者，你已經走過了不同的理財道路。"]},{"code":401,"indent":0,"parameters":["你學會了等待，也體驗了風險。"]},{"code":401,"indent":0,"parameters":["你看過穩定成長的力量，也見過不確定性帶來的改變。"]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["星海不會要求每個人走同一條路，"]},{"code":401,"indent":0,"parameters":["但當一位冒險者已經親身體驗過不同選擇，"]},{"code":401,"indent":0,"parameters":["就代表──"]},{"code":401,"indent":0,"parameters":["他已經有資格面對真正的配置考驗。"]},{"code":121,"indent":0,"parameters":[14,14,0]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["看見那道光了嗎?"]},{"code":401,"indent":0,"parameters":["那裡是星衡之域。"]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["在那裡，你無法使用目前賺取的所有星幣，"]},{"code":401,"indent":0,"parameters":["星海將賦予你10000元的初始星幣，"]},{"code":401,"indent":0,"parameters":["請依照自己的判斷，決定如何分配在儲蓄與不同風險的投資上。"]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["那不是對與錯的測驗，"]},{"code":401,"indent":0,"parameters":["而是一場屬於你的決策試煉。"]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["不過，是否現在就前往，"]},{"code":401,"indent":0,"parameters":["由你自己決定。"]},{"code":401,"indent":0,"parameters":["你可以立刻進入最終考核，"]},{"code":401,"indent":0,"parameters":["也可以先繼續在星海中探索、練習、觀察。"]},{"code":101,"indent":0,"parameters":["",0,0,2,""]},{"code":401,"indent":0,"parameters":["當你覺得準備好了。在踏入那裡也不遲。"]},{"code":401,"indent":0,"parameters":["因為一旦進入最終考核，想回頭也來不及了。"]},{"code":0,"indent":0,"parameters":[]}],"moveF